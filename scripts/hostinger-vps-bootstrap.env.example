export DOMAIN="serpely.com"
export WWW_DOMAIN="www.serpely.com"
export APP_DIR="/var/www/Serpely"
export APP_USER="root"
export ADMIN_EMAIL="admin@serpely.com"
export PORT="4000"

export MONGO_URI="mongodb+srv://username:password@cluster.mongodb.net/Serpely?appName=Cluster0"
export ADMIN_PASSWORD="StrongPassword123!"

# Optional: set your own instead of auto-generating one.
# export JWT_SECRET="replace_with_a_very_long_random_secret_at_least_32_characters"
